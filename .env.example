# Copy this file to .env and fill in your own private values.
# Never commit .env or real API keys/passwords to GitHub.

# Google Gemini / AI Studio API key
GEMINI_API_KEY="your_gemini_api_key_here"

# App URL used for reset links and callbacks
APP_URL="http://localhost:3000"

# MongoDB Atlas connection string
MONGODB_URI="mongodb+srv://username:password@cluster.mongodb.net/rksAI?retryWrites=true&w=majority"

# JWT signing secret. Use a long random value in production.
JWT_SECRET="replace_with_a_long_random_secret"

# Initial admin user created/updated on server startup
INITIAL_ADMIN_EMAIL="admin@example.com"
INITIAL_ADMIN_PASSWORD="replace_with_a_strong_password"
